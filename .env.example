# Copy to .env and fill in. Never commit .env.

# --- PostgreSQL ---
# Used by the ingestion pipeline (src/) and the Looker Studio data source.
PGHOST=localhost
PGPORT=5432
PGDATABASE=hospital_dashboard
PGUSER=hospital_app
PGPASSWORD=change-me-strong-password

# Superuser creds, only used by sql/00_init.sql when bootstrapping the DB+role.
PG_SUPERUSER=postgres
PG_SUPERUSER_PASSWORD=change-me

# --- CMS Provider Data Catalog ---
# Base URL for the new DKAN-style API. NOTE: the legacy data.cms.gov SODA API
# is deprecated; do not use /resource/ or /api/views/ paths.
CMS_API_BASE=https://data.cms.gov/provider-data/api/1

# Page size for /datastore/query pagination. CMS doesn't publish a hard cap,
# but 5000 is comfortable.
CMS_PAGE_SIZE=5000

# Optional: override which datasets the pipeline pulls. Comma-separated 4x4 IDs.
CMS_DATASET_IDS=xubh-q36u,dgck-syfz,632h-zaca

# --- Pipeline behavior ---
LOG_LEVEL=INFO
# If true, ingestion truncates raw tables before loading. Use for full refresh.
RAW_TRUNCATE_ON_LOAD=true
